--[[

____ FUNCTION - NEW_INSTANCE _______________________________________________________________________________________________________________________________________________

Creates and returns a new Defin instance

className:	Name of the class to be instanced
parent (optional):		Parent of the instance
container (optional):	ROBLOX instance that will be wrapped by the custom instance

--]]

function defin:NewInstance(className, parent, container)
	local class, instance
	
	if type(className) == "table" then
		instance = className
		container = instance["1"]
		className = instance["2"]
		
		if defin:IsWrapped(instance) then
			return instance
		else
			class = classes[className] or services[className]
		end
	else
		class = classes[className] or services[className]
		instance = {}
		
		if not class then
			error('Unable to create a Defin Instance of type "' .. className .. '"')
		end
		
		for index, value in pairs(class.PropertyIndexes) do
			instance[value] = defin:CloneValue(class.Properties[index])
		end
		
		if containers[className] or containers[container] then
			if typeof(container) ~= "Instance" then
				if container then
					container = containers[container]
				else
					container = containers[className]
				end

				if services[className] then
					container.Parent = parent
				else
					container = container:Clone()
				end
			elseif not container:FindFirstChild("PackageLink") then
				for _, child in pairs(containers[className]:GetChildren()) do
					if not container:FindFirstChild(child.Name) and not child:IsA("PackageLink") then
						child:Clone().Parent = container
					end
				end
			end
		else
			container = container or Instance.new(class.ContainerClassName or "Folder")
		end
		
		instance["1"] = container
		instance["2"] = className
		instance["3"] = instance["3"] or tostring(instance):sub(8)
		instance["4"] = services[className] ~= nil

		if not container.Parent then
			container.Name = className
			container.Parent = defin:Unwrap(parent)
		end
		
		collectionService:AddTag(container, "Defin")
	end
	
	container.AncestryChanged:Connect(function()
		if not instance:IsDescendantOf(game) then
			destroyInstance(instance)
		end
	end)
	
	instance = setmetatable(instance, definMetatable)

	initializeInstance(instance)

	if isServer then
		if not checkReplicationBundle(instance) then
			replicateInstance(instance)
		end
		
		instance:GetPropertyChangedSignal("Parent"):Connect(function()
			if not checkReplicationBundle(instance) then
				replicateInstance(instance)
			end
		end)
	end
	
	return instance
end

--[[
	
____ FUNCTION - IS_WRAPPED _________________________________________________________________________________________________________________________________________________

Returns whether or not a value is wrapped into a Defin instance

value: The value

--]]

function defin:IsWrapped(value)
	return getmetatable(value) == DEFIN_LOCKED
end

--[[
	
____ FUNCTION - WRAP _______________________________________________________________________________________________________________________________________________________

Returns the wrapped Defin instance of a value or the value itself

value: The value to be wrapped

--]]

function defin:Wrap(value)
	return instances[value] or value
end

--[[

____ FUNCTION - UNWRAP _____________________________________________________________________________________________________________________________________________________

Returns the unwrapped value of a value

value: The value to be unwrapped

--]]

function defin:Unwrap(value)
	if defin:IsWrapped(value) then
		return value["1"]
	else
		return value
	end
end

--[[

____ FUNCTION - WAIT_FOR_WRAP ______________________________________________________________________________________________________________________________________________

Yields for the value to be wrapped then returns it

value: The value to wait to be wrapped

--]]

function defin:WaitForWrap(value, timeOut)
	if value then
		local start = tick()
		local warned = false

		while true do
			local wrappedValue = defin:Wrap(value)

			if defin:IsWrapped(wrappedValue) then
				return wrappedValue
			elseif typeof(value) == "Instance" and collectionService:HasTag(value, "Defin") then
				if timeOut and tick() - start > timeOut then
					return
				elseif not warned and not timeOut and tick() - start > 5 then
					warn("Infinite yield possible on 'Defin:WaitForWrap(" .. value.Name .. ")'")
					
					warned = true
				end

				runService.Heartbeat:Wait()
			else
				return
			end
		end
	end
end

--[[

____ FUNCTION - GET_SERVICE ______________________________________________________________________________________________________________________________________________

Yields for the service to be initialized then returns it

serviceName: The name of the service
ignoreInitialization: Ignores whether or not the server has finished initializing (cheap solution to avoiding cyclic dependency)

--]]

function defin:GetService(serviceName, ignoreInitialization)
	if not serviceInstances[serviceName] and not ignoreInitialization then
		while not serviceInstances[serviceName] do
			runService.Heartbeat:Wait()
		end
	end
	
	return serviceInstances[serviceName]
end

--[[

____ FUNCTION - GET_PLUGIN ______________________________________________________________________________________________________________________________________________

Plugins can be added inside the Plugins folder

pluginName: The name of the plugin

--]]

function defin:GetPlugin(pluginName)
	return plugins[pluginName]
end

function defin:PauseInstanceReplication(instance)
	if not isInstanceReplicationPaused(instance) then
		pausedInstanceReplications[instance] = {}
	end
end

function defin:ContinueInstanceReplication(instance)
	local updates = pausedInstanceReplications[instance]

	if updates then
		pausedInstanceReplications[instance] = nil

		if #updates > 0 then
			eventsFolder.InstanceReplicationContinued:FireAllClients(defin:Unwrap(instance), updates)
		end
	end
end

function defin:BindToReplicationBundle(classes)
	for _, class in pairs(classes) do
		if not replicationBundles[class] then
			replicationBundles[class] = {}
		end
	end
end

function defin:UnbindFromReplicationBundle(classes)
	for _, class in pairs(classes) do
		local _instances = replicationBundles[class]

		if _instances and #_instances > 0 then
			for _, instance in pairs(_instances) do
				instance["4"] = true
			end

			eventsFolder.InstancesAdded:FireAllClients(_instances)
		end

		replicationBundles[class] = nil
	end
end

function defin:GetRawContainer(className)
	return containers[className]
end

function defin:GetContainer(className)
	return containers[className]:Clone()
end

function defin:GetPlayer()
	local player = defin:Wrap(localPlayer)
	
	if player and not defin:IsWrapped(player) then
		player = defin:WaitForWrap(player)
	end
	
	return player
end

function defin:IsAClass(className)
	return classes[className] ~= nil
end

function defin:IsAClassFunction(classNameOrInstance, functionName)
	return type(classes[defin:IsWrapped(classNameOrInstance) and classNameOrInstance.ClassName or classNameOrInstance][functionName]) == "function"
end

function defin:IsClient()
	return isClient
end

function defin:IsServer()
	return isServer
end

function defin:IsStudio()
	return isStudio
end

function defin:GetConstants(className)
	return (classes[className] or components[className]).Constants
end

function defin:GetProperties(className)
	return (classes[className] or components[className]).Properties
end

function defin:ClassHasComponent(className, componentName)
	local class = classes[className]

	if class then
		if componentName then
			return table.find(class.Components, componentName) ~= nil
		else
			return #class.Components > 0
		end
	end
end

function defin:ClassHasAnyComponent(className, componentNames)
	for _, componentName in pairs(componentNames) do
		if defin:ClassHasComponent(className, componentName) then
			return true
		end
	end
	
	return false
end

function defin:GetClassesWithComponent(componentName)
	if classesWithComponent[componentName] then
		return classesWithComponent[componentName]
	else
		local classNames = {}

		for className, class in pairs(classes) do
			if table.find(class.Components, componentName) then
				table.insert(classNames, className)
			end
		end

		classesWithComponent[componentName] = classNames

		return classNames
	end
end

function defin:GetClassesWithAnyComponent(componentNames)
	local classNames = {}

	for className, class in pairs(classes) do
		for _, component in ipairs(componentNames) do
			if table.find(class.Components, component) then
				table.insert(classNames, className)
				break
			end
		end
	end

	return classNames
end

function defin:GetClassComponents(className)
	return classes[className].Components
end

function defin:GetComponents()
	local names = {}
	for name, _ in pairs(components) do
		table.insert(names, name)
	end
	return names
end

function defin:WrapTable(_table, waitForWrap)
	if type(_table) == "table" then
		local wrappedTable = {}
		for index, value in pairs(_table) do
			if waitForWrap and typeof(value) == "Instance" and collectionService:HasTag(value, "Defin") then
				wrappedTable[index] = defin:WaitForWrap(value, 10)
			else
				wrappedTable[index] = defin:Wrap(value)
			end
		end
		return wrappedTable
	end
end

function defin:UnwrapTable(_table)
	if type(_table) == "table" then
		local unwrappedTable = {}
		
		for index, value in pairs(_table) do
			unwrappedTable[index] = defin:Unwrap(value)
		end
		
		return unwrappedTable
	end
end

function defin:CloneValue(value)
	if type(value) == "table" then
		local _table = {}
		
		for index, _value in pairs(value) do
			_table[index] = defin:CloneValue(_value)
		end
		
		return _table
	elseif typeof(value) == "Instance" then
		local clone = value:Clone()
		clone.Parent = value.Parent
		
		return clone
	else
		return value
	end
end

function startInstanceThread(instance, name)
	if not isInstanceThreadActive(instance, name) then
		local class = getClassForInstance(instance)
		local func = class.Thread[name]

		if func then
			local container = instance.Container
			local _instanceThreads = instanceThreads[container]

			if not _instanceThreads then
				_instanceThreads = {}

				instanceThreads[container] = _instanceThreads
			end

			table.insert(_instanceThreads, name)

			coroutine.wrap(function()
				local delta = 0
				local _delay, paramA, paramB, paramC

				while instances[container] and isInstanceThreadActive(instance, name) do
					_delay, paramA, paramB, paramC = func(instance, delta, paramA, paramB, paramC)

					local _tick = tick()

					task.wait(_delay or 1)

					delta = tick() - _tick
				end
			end)()
		end
	end
end

function stopInstanceThread(instance, name)
	if isInstanceThreadActive(instance, name) then
		local container = instance.Container
		local index = table.find(instanceThreads[container], name)

		table.remove(instanceThreads[container], index)
	end
end

function isInstanceThreadActive(instance, name)
	local container = instance.Container
	local _instanceThreads = instanceThreads[container]

	if _instanceThreads then
		return table.find(_instanceThreads, name) ~= nil
	else
		return false
	end
end

