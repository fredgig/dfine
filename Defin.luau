definMetatable = {
	__metatable = DEFIN_LOCKED,

	__tostring = function(instance)
		return instance.Name .. " (" .. instance.ClassName .. ")"
	end,
	
	__index = function(instance, index)
		local class = getClassForInstance(instance)

		if index == "Container" then
			return instance["1"]
		elseif index == "ClassName" then
			return instance["2"]
		elseif index == "Id" then
			return instance["3"]
		elseif class.PropertyIndexes[index] then
			return defin:Wrap(rawget(instance, class.PropertyIndexes[index]))
		elseif class.ConstantIndexes[index] then
			return class.Constants[index]
		elseif type(class[index]) == "function" then
			return class[index]
		elseif type(instance["1"][index]) == "function" then
			return function(_, ...)
				return defin:Wrap(instance["1"][index](instance["1"], ...))
			end
		else
			return defin:Wrap(instance["1"][index])
		end
	end,
		
	__newindex = function(instance, index, newValue)
		local class = getClassForInstance(instance)
		local propertyIndex = class.PropertyIndexes[index]

		newValue = defin:Unwrap(newValue)
		
		if propertyIndex then
			local changed

			changed = changeInstanceProperty(instance, index, newValue, false, false)

			if changed and canReplicateInstance(instance) then
				eventsFolder.InstancePropertyFunction:FireAllClients(instance["1"], index, newValue)
			elseif isInstanceReplicationPaused(instance) then
				queueInstanceReplicationUpdate(instance, {
					1,
					index,
					newValue
				})
			end
		else
			instance["1"][index] = newValue
		end
	end
}

function initializeInstance(instance)
	if not instances[instance.Container] then
		local class = getClassForInstance(instance)
		
		instances[instance.Container] = instance
		
		for _, value in pairs(instance) do
			defin:WaitForWrap(value, 10)
		end
		
		for _, componentName in pairs(class.Components) do
			local func = class.InitializedFunctions[componentName]
			
			if type(func) == "function" then
				func(instance)
			end
		end
		
		local func = class.InitializedFunctions.Class
		
		if type(func) == "function" then
			func(instance)
		end
		
		for index in pairs(class.PropertyIndexes) do
			changeInstanceProperty(instance, index, instance[index], true, false)
		end
	end
end

function changeInstanceProperty(instance, propertyName, newValue, initializing, replicating)
	local class = getClassForInstance(instance)
	local index = class.PropertyIndexes[propertyName]
	local oldValue = rawget(instance, index)
	
	if (newValue ~= oldValue or initializing) and newValue ~= instance.Container then
		rawset(instance, index, newValue)
		
		local funcs = class.ChangedFunctions[propertyName]
		
		if funcs then
			oldValue = defin:Wrap(oldValue)
			newValue = defin:Wrap(newValue)
			
			for _, componentName in pairs(class.Components) do
				local func = funcs[componentName]
				
				if type(func) == "function" then
					func(instance, newValue, oldValue, initializing, replicating)
				end
			end
			
			local func = funcs.Class
			
			if type(func) == "function" then
				func(instance, newValue, oldValue, initializing, replicating)
			end
		end
		
		return true
	else
		return false
	end
end

function destroyInstance(instance)
	local class = getClassForInstance(instance)
	local container = instance.Container
	
	if instances[container] then
		instanceThreads[container] = nil
		
		for _, componentName in pairs(class.Components) do
			local func = class.DestroyedFunctions[componentName]
			
			if type(func) == "function" then
				if isStudio then
					func(instance)
				else
					pcall(function()
						func(instance)
					end)
				end
			end
		end
		
		local func = class.DestroyedFunctions.Class
		
		if type(func) == "function" then
			if isStudio then
				func(instance)
			else
				pcall(function()
					func(instance)
				end)
			end
		end
		
		instances[container] = nil
		
		container:Destroy()
	end
end

function queueInstanceReplicationUpdate(instance, update)
	local updates = pausedInstanceReplications[instance]

	if updates then
		table.insert(updates, update)
	end
end

function getClassForInstance(instance)
	return classes[instance["2"]] or services[instance["2"]]
end

function requireModule(_table, moduleScript)
	local moduleName = moduleScript.Name
	local module = require(moduleScript)
	
	_table[moduleName] = module
	
	if isClient then
		hideInstance(moduleScript)
	end
end

function setupClassComponents(class, component)
	component = component or class

	for _, componentName in pairs(component.Components) do
		if not table.find(class.Components, componentName) then
			table.insert(class.Components, componentName)
		end

		local _component = components[componentName]

		setupClassComponents(class, _component)
	end
end

function setupModule(moduleName, moduleType, module)
	if moduleType == "Class" or moduleType == "Service" then
		module.InitializedFunctions = {}
		module.ChangedFunctions = {}
		module.DestroyedFunctions = {}

		setupClassComponents(module)
	
		for _, componentName in pairs(module.Components) do
			local component = components[componentName]
			
			if not component then
				error('"' .. componentName .. '" is not a valid component for class ' .. moduleName)
			end

			if not module.ContainerClassName and type(component.ContainerClassName) == "string" then
				module.ContainerClassName = component.ContainerClassName
			end
			
			for index, value in pairs(component.Constants) do
				if type(index) == "string" then
					if module.Constants[index] == nil  then
						if value == defin.Nil then
							value = nil
						end
						module.Constants[index] = value
					elseif type(value) == "table" and type(module.Constants[index]) == "table" then
						if isArray(value) and isArray(module.Constants[index]) then
							if not module.Constants[index] then
								module.Constants[index] = value
							end
						else
							for _index, _value in pairs(value) do
								if module.Constants[index][_index] == nil then
									module.Constants[index][_index] = _value
								end
							end
						end
					end
				end
			end
			
			for index, value in pairs(component.Properties) do
				if type(index) == "string" then
					if module.Properties[index] == nil  then
						if value == defin.Nil then
							value = nil
						end
						module.Properties[index] = value
					elseif type(value) == "table" and type(module.Properties[index]) == "table" then
						if isArray(value) and isArray(module.Properties[index]) then
							if not module.Properties[index] then
								module.Properties[index] = value
							end
						else
							for _index, _value in pairs(value) do
								if module.Properties[index][_index] == nil then
									module.Properties[index][_index] = _value
								end
							end
						end
					end
				end
			end
			
			for index, value in pairs(component) do
				if type(value) == "function" and not module[index] and index ~= "Initialized" and index ~= "Destroyed" then
					module[index] = value
				end
			end

			for index, value in pairs(component.Thread) do
				if type(value) == "function" and not module.Thread[index] then
					module.Thread[index] = value
				end
			end
			
			for index, value in pairs(component[context]) do
				if type(value) == "function" and not module[context][index] and index ~= "Initialized" and index ~= "Destroyed" then
					module[context][index] = value
				end
			end

			for index, value in pairs(component[context].Thread) do
				if type(value) == "function" and not module[context].Thread[index] then
					module[context].Thread[index] = value
				end
			end
			
			if type(component.Initialized) == "function" then
				module.InitializedFunctions[componentName] = component.Initialized
			end
			
			if type(component[context].Initialized) == "function" then
				module.InitializedFunctions[componentName] = component[context].Initialized
			end
			
			for index, value in pairs(component.Changed) do
				if type(value) == "function" then
					if not module.ChangedFunctions[index] then
						module.ChangedFunctions[index] = {}
					end
					module.ChangedFunctions[index][componentName] = value
				end
			end
			
			for index, value in pairs(component[context].Changed) do
				if type(value) == "function" then
					if not module.ChangedFunctions[index] then
						module.ChangedFunctions[index] = {}
					end
					module.ChangedFunctions[index][componentName] = value
				end
			end
			
			for index, value in pairs(component.Server.Request) do
				if type(value) == "function" and not module.Server.Request[index] then
					module.Server.Request[index] = value
				end
			end
			
			for index, value in pairs(component.Client.Replicate) do
