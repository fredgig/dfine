				end
			end
			
			if type(component.Destroyed) == "function" then
				module.DestroyedFunctions[componentName] = component.Destroyed
			end
			
			if type(component[context].Destroyed) == "function" then
				module.DestroyedFunctions[componentName] = component[context].Destroyed
			end
		end
	
		module.PropertyIndexes = {}
		module.ConstantIndexes = {}
	
		local _index = 5
		
		for index, value in pairs(module.Constants) do
			if type(index) == "string" then
				module.ConstantIndexes[index] = tostring(_index)
			else
				error('Constant index "' .. tostring(index) .. '" must be a string (' .. moduleName .. ')')
			end

			_index = _index + 1
		end

		_index = 5

		for index, value in pairs(module.Properties) do
			if type(index) == "string" then
				module.PropertyIndexes[index] = tostring(_index)
			else
				error('Property index "' .. tostring(index) .. '" must be a string (' .. moduleName .. ')')
			end
			
			_index = _index + 1
		end

		for index, value in pairs(module[context]) do
			if type(value) == "function" then
				module[index] = value
			end
		end
		
		for index, value in pairs(module[context].Thread) do
			if type(value) == "function" then
				module.Thread[index] = value
			end
		end
		
		if type(module.Initialized) == "function" then
			module.InitializedFunctions.Class = module.Initialized
		end
		
		if type(module[context].Initialized) == "function" then
			module.InitializedFunctions.Class = module[context].Initialized
		end
		
		for index, value in pairs(module.Changed) do
			if type(value) == "function" then
				if not module.ChangedFunctions[index] then
					module.ChangedFunctions[index] = {}
				end
				module.ChangedFunctions[index].Class = value
			end
		end
		
		for index, value in pairs(module[context].Changed) do
			if type(value) == "function" then
				if not module.ChangedFunctions[index] then
					module.ChangedFunctions[index] = {}
				end
				module.ChangedFunctions[index].Class = value
			end
		end
		
		if type(module.Destroyed) == "function" then
			module.DestroyedFunctions.Class = module.Destroyed
		end
		
		if type(module[context].Destroyed) == "function" then
			module.DestroyedFunctions.Class = module[context].Destroyed
		end
		
		module.Request = module.Server.Request
		module.Replicate = module.Client.Replicate
		
		if isClient then
			for index in pairs(module.Request) do
				module["Request" .. index] = function(instance, ...)
					return eventsFolder.InstanceRequestFunction:InvokeServer(instance.Container, index, unpack(defin:UnwrapTable({ ... })))
				end
			end
		else
			for index in pairs(module.Replicate) do
				module["Replicate" .. index] = function(instance, ...)
					if canReplicateInstance(instance) then
						eventsFolder.InstanceReplicateFunction:FireAllClients(instance["1"], index, unpack(defin:UnwrapTable({ ... })))
					elseif isInstanceReplicationPaused(instance) then
						queueInstanceReplicationUpdate(instance, {
							2,
							false,
							index,
							defin:UnwrapTable({ ... })
						})
					end
				end
				
				module["ReplicatePlayer" .. index] = function(instance, player, ...)
					if canReplicateInstance(instance) then
						eventsFolder.InstanceReplicateFunction:FireClient(defin:Unwrap(player), instance["1"], index, unpack(defin:UnwrapTable({ ... })))
					elseif isInstanceReplicationPaused(instance) then
						queueInstanceReplicationUpdate(instance, {
							2,
							defin:Unwrap(player),
							index,
							defin:UnwrapTable({ ... })
						})
					end
				end
			end
		end
		
		if moduleType == "Class" then
			function module:Clone()
				return defin:NewInstance(defin:CloneValue(self))
			end

			function module:SetClass(className)
				if classes[className] then
					rawset(self, "2", className)

					if isServer then
						eventsFolder.InstanceClassChanged:FireAllClients(self.Container, className)
					end
				end
			end

			function module:StartThread(name)
				startInstanceThread(self, name)
			end

			function module:StopThread(name)
				stopInstanceThread(self, name)
			end

			function module:IsThreadActive(name)
				isInstanceThreadActive(self, name)
			end
		end

		function module:IsA(_className)
			return self.ClassName == _className or _className == "DefinInstance" or self.Container:IsA(_className) or table.find(module.Components, _className) ~= nil
		end

		function module:Debug(...)
			if DEBUG then
				print(self, ...)
			end
		end
	end
end

function setupContainers()
	local physicalContainers = workspace:FindFirstChild("PhysicalContainers")

	if physicalContainers then
		for _, container in pairs(physicalContainers:GetChildren()) do
			container.Parent = replicatedStorage.Containers
		end

		physicalContainers:Destroy()
	end

	for _, container in pairs(replicatedStorage.Containers:GetChildren()) do
		containers[container.Name] = container
	end
end

function setupModules()
	for moduleName, module in pairs(components) do
		setupModule(moduleName, "Component", module)
	end
	
	for moduleName, module in pairs(classes) do
		setupModule(moduleName, "Class", module)
	end

	for moduleName, module in pairs(services) do
		setupModule(moduleName, "Service", module)
	end
end

function requireModules()
	for _, module in pairs(script:GetDescendants()) do
		if module:IsA("ModuleScript") then
			local moduleType = module:FindFirstAncestorOfClass("Configuration")
			moduleType = moduleType and moduleType.Name
			
			local _table = tablesForModuleTypes[moduleType]

			if _table then
				requireModule(_table, module)
			end
		end
	end
end

function hideInstance(instance)
	if instance then
		instance.Name = ""
		instance.Parent = createFolder("", createFolder("", createFolder("")))
		
		return instance
	end
end

function createFolder(name, parent)
	local folder
	
	if parent then
		folder = parent:FindFirstChild(name)
	end
	
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = name
		folder.Parent = parent
	end
	
	return folder
end

function combineTables(table1, table2)
	for index, value in pairs(table1) do
		if type(value) == "table" and type(table2[index]) == "table" then
			combineTables(value, table2[index])
		else
			table2[index] = value
		end
	end
	
	return table2
end

function isArray(_table)
	if type(_table) == "table" then
		local amount = 0
		
		for _ in pairs(_table) do
			amount = amount + 1
		end
		
		return amount > 0 and #_table == amount
	end
end

function isInstanceReplicated(instance)
	return instance["4"]
end

function isInstanceReplicationPaused(instance)
	return pausedInstanceReplications[instance] ~= nil
end

function canReplicateInstance(instance)
	return isServer and isInstanceReplicated(instance) and not isInstanceReplicationPaused(instance)
end

function replicateInstance(instance)
	if instance.Parent and not instance:IsDescendantOf(serverStorage) and not instance:IsDescendantOf(serverScriptService) and instance.Parent ~= game and classes[instance.ClassName] then
		instance["4"] = true
		eventsFolder.InstanceAdded:FireAllClients(instance)
	end
end

function checkReplicationBundle(instance)
	for class, _instances in pairs(replicationBundles) do
		if instance:IsA(class) then
			table.insert(_instances, instance)
			return true
		end
	end
	
	return false
end

function getModulesAmount()
	return #script.Classes:GetChildren() + #script.Services:GetChildren() + #script.Components:GetChildren()
end

function checkPlayerRequest(player, requestName)
	if playerRequests[player.UserId][requestName] then
		player:Kick("D1")
		
		return false
	else
		playerRequests[player.UserId][requestName] = tick()
		
		return true
	end
end

function endClient()
	while true do	end
end

function initialize()
	-- Set context

	if isClient then
		context = "Client"
		
		if not isStudio then
			hideInstance(script)

			local modulesAmount = getModulesAmount()
			local definIndexes = 0

			setmetatable(_G, {
				__metatable = DEFIN_LOCKED,
				
				__index = function(_, index)
					if index == "Defin" then
						if definIndexes < modulesAmount then
							definIndexes = definIndexes + 1
							
							return defin
						else
							endClient()
						end
					end
				end
			})
		end

		eventsFolder = replicatedStorage.DefinEvents

		eventsFolder.InstancePropertyFunction.OnClientEvent:Connect(function(instanceContainer, propertyName, newValue)
			if instanceContainer then
				local instance = defin:WaitForWrap(instanceContainer, 10)

				if defin:IsWrapped(instance) then
					changeInstanceProperty(instance, propertyName, newValue, false, true)
				end
			end
		end)

		eventsFolder.InstanceReplicateFunction.OnClientEvent:Connect(function(instanceContainer, functionName, ...)
			if instanceContainer then
				local instance = defin:WaitForWrap(instanceContainer, 10)
				
				if defin:IsWrapped(instance) then
					local class = getClassForInstance(instance)
					local func = class.Replicate[functionName]

					func(instance, unpack(defin:WrapTable({ ... }, true)))
				end
			end
		end)
	elseif isServer then
		context = "Server"

		_G.DefinVersion = 181

		eventsFolder = createFolder("DefinEvents", replicatedStorage)
		
		Instance.new("RemoteFunction", eventsFolder).Name = "GetServiceInstances"
		Instance.new("RemoteFunction", eventsFolder).Name = "GetClassInstances"
		Instance.new("RemoteEvent", eventsFolder).Name = "InstanceAdded"
		Instance.new("RemoteEvent", eventsFolder).Name = "InstancesAdded"
		Instance.new("RemoteEvent", eventsFolder).Name = "InstanceReplicationContinued"
		Instance.new("RemoteEvent", eventsFolder).Name = "InstanceClassChanged"
		Instance.new("RemoteEvent", eventsFolder).Name = "InstancePropertyFunction"
		Instance.new("RemoteFunction", eventsFolder).Name = "InstanceRequestFunction"
		Instance.new("RemoteEvent", eventsFolder).Name = "InstanceReplicateFunction"

		eventsFolder.InstanceRequestFunction.OnServerInvoke = function(player, instanceContainer, functionName, ...)
			local instance = defin:Wrap(instanceContainer)
			
			if defin:IsWrapped(instance) then
				local class = getClassForInstance(instance)
				local func = class.Request[functionName]
				
				if type(func) == "function" then
					return func(instance, defin:Wrap(player), unpack(defin:WrapTable({ ... })))
				end
			end
		end
	end

	_G.Defin = defin
	
	-- Setup modules

	setupContainers()
	requireModules()
	setupModules()

	defin.Content = replicatedStorage:WaitForChild("Content")

	if isClient then
		if not isStudio then
			_G.Defin = nil
		end
		
		for _, instance in pairs(eventsFolder.GetServiceInstances:InvokeServer()) do
			task.spawn(function()
				serviceInstances[instance["2"]] = defin:NewInstance(instance)
			end)
		end
	
		for _, service in pairs(serviceInstances) do
			defin:WaitForWrap(service)
		end
		
		eventsFolder.InstanceAdded.OnClientEvent:Connect(function(instance)
			if instance["1"] then
				defin:NewInstance(instance)
			end
		end)
		
		eventsFolder.InstancesAdded.OnClientEvent:Connect(function(instances)
			for _, instance in pairs(instances) do
				if instance["1"] then
					task.spawn(function()
						defin:NewInstance(instance)
					end)
				end
			end
		end)

		eventsFolder.InstanceReplicationContinued.OnClientEvent:Connect(function(instanceContainer, updates)
			local instance = instances[instanceContainer]

			if instance then
				local class = getClassForInstance(instance)

				for _, update in pairs(updates) do
					local _type = update[1]

					if _type == 1 then
						local propertyName = update[2]
						local propertyValue = update[3]

						changeInstanceProperty(instance, propertyName, propertyValue, false, true)
					elseif _type == 2 then
						local forPlayer = update[2]

						if not forPlayer or forPlayer == localPlayer then
							local functionName = update[3]
							local parameters = update[4]
							local func = class.Replicate[functionName]

							func(instance, unpack(defin:WrapTable(parameters, true)))
						end
					end
				end
			end
		end)

		for _, instance in pairs(eventsFolder.GetClassInstances:InvokeServer()) do
			if instance["1"] then
				task.spawn(function()
					defin:NewInstance(instance)
				end)
			end
		end
		
		eventsFolder.InstanceClassChanged.OnClientEvent:Connect(function(instanceContainer, className)
			local instance = instances[instanceContainer]

			if instance then
				instance:SetClass(className)
			end
		end)

		if not isStudio then
			eventsFolder.GetServiceInstances:Destroy()
			eventsFolder.GetClassInstances:Destroy()
			hideInstance(eventsFolder.InstanceAdded)
			hideInstance(eventsFolder.InstancesAdded)
			hideInstance(replicatedStorage.Content)
			hideInstance(replicatedStorage.Containers)
		end
	elseif isServer then
		-- Return all existing instances when invoked by a client
		
		eventsFolder.GetServiceInstances.OnServerInvoke = function(player)
			if checkPlayerRequest(player, "GetServiceInstances") then
				playerRequests[player.UserId].GetServiceInstances = tick()
				local _instances = {}
				
				for index, _ in pairs(services) do
					local service = defin:GetService(index)
					table.insert(_instances, service)
				end
				
				return _instances
			end
		end

		eventsFolder.GetClassInstances.OnServerInvoke = function(player)
			if checkPlayerRequest(player, "GetClassInstances") then
				local _instances = {}
				
				for _, instance in pairs(instances) do
					if classes[instance.ClassName] then
						table.insert(_instances, instance)
					end
				end
				
				return _instances
			end
		end

		-- Instance and index to serviceInstances all game services

		for index, _ in pairs(services) do
			task.spawn(function()
				serviceInstances[index] = defin:NewInstance(index, replicatedStorage)
			end)
		end

		-- Instance player class on join
		
		players.PlayerAdded:Connect(function(player)
			playerRequests[player.UserId] = {}

			if classes.Player then
				defin:NewInstance("Player", nil, player)
			end
		end)
		
		players.PlayerRemoving:Connect(function(player)
			playerRequests[player.UserId] = nil
		end)
	end
end

initialize()

